import os
import logging
from telegram import Update
from telegram.ext import Application, CommandHandler, MessageHandler, filters, ContextTypes
import yt_dlp

# Enable logging for tracking bot activity on the server
logging.basicConfig(
    format='%(asctime)s - %(name)s - %(levelname)s - %(message)s', 
    level=logging.INFO
)
logger = logging.getLogger(__name__)

# Fetch Token from Environment Variables (Best practice for Koyeb/Render)
TOKEN = os.getenv("TELEGRAM_BOT_TOKEN", "YOUR_FALLBACK_TOKEN_HERE")

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    welcome_text = (
        "👋 Hello! I am your Bunny.net Video Downloader Bot.\n\n"
        "Please send me a valid secured `.m3u8` link, and I will download and convert it to MP4 for you."
    )
    await update.message.reply_text(welcome_text)

async def download_video(update: Update, context: ContextTypes.DEFAULT_TYPE):
    url = update.message.text
    
    if "m3u8" not in url:
        await update.message.reply_text("❌ Error: Invalid link. Please provide a valid .m3u8 link.")
        return

    status_msg = await update.message.reply_text("📥 Fetching stream and downloading to server... Please wait.")

    # Optimized headers extracted from your Requable session
    ydl_opts = {
        'http_headers': {
            'Referer': 'https://iframe.mediadelivery.net/',
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) eoe-app/1.0.2 Chrome/108.0.5359.215 Electron/22.3.27 Safari/537.36'
        },
        'outtmpl': 'video.mp4',
        'concurrent_fragment_downloads': 5, # High-speed parallel downloading
        'format': 'best',
        'quiet': True,
        'no_warnings': True
    }

    try:
        # Download using yt-dlp
        with yt_dlp.YoutubeDL(ydl_opts) as ydl:
            ydl.download([url])
        
        # Check if file exists and handle Telegram's 50MB upload limit for standard bots
        if os.path.exists('video.mp4'):
            file_size_mb = os.path.getsize('video.mp4') / (1024 * 1024)
            
            if file_size_mb > 50:
                await status_msg.edit_text(
                    f"⚠️ File is too large ({file_size_mb:.2f} MB).\n"
                    f"Telegram API restricts standard bots from uploading files larger than 50MB."
                )
                return

            await status_msg.edit_text("📤 Download complete! Uploading video to Telegram...")
            
            # Send the video file
            with open('video.mp4', 'rb') as video:
                await update.message.reply_video(
                    video=video, 
                    timeout=300, 
                    caption="🚀 Here is your requested video!"
                )
            await status_msg.delete()
        else:
            await status_msg.edit_text("❌ Error: Processed video file not found.")

    except Exception as e:
        logger.error(f"Error during execution: {str(e)}")
        await status_msg.edit_text(f"❌ An error occurred: {str(e)}")
        
    finally:
        # Absolute bug prevention: Ensure disk space is always cleared regardless of success/fail
        if os.path.exists('video.mp4'):
            try:
                os.remove('video.mp4')
            except Exception as cleanup_error:
                logger.error(f"Failed to delete temp file: {str(cleanup_error)}")

def main():
    if TOKEN == "YOUR_FALLBACK_TOKEN_HERE" or not TOKEN:
        print("CRITICAL ERROR: Telegram Bot Token is missing!")
        return

    app = Application.builder().token(TOKEN).build()
    
    app.add_handler(CommandHandler("start", start))
    app.add_handler(MessageHandler(filters.TEXT & ~filters.COMMAND, download_video))
    
    print("Bot is up and running smoothly...")
    app.run_polling()

if __name__ == '__main__':
    main()
